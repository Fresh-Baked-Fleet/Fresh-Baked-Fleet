@using BlazorApp.Models
@using BlazorApp.Components.Orders

<div class="product-card">
    <a class="product-card-link" href="@($"/products/{Product.Id}")">
        <div class="product-image-container">
            <img src="@Product.ImagePath" alt="@Product.Name" width="200" />
            <span class=@("product-status" + (Product.Available ? " available" : " unavailable"))>
                @(Product.Available ? "Available" : "Unavailable")
            </span>
        </div>

        <h3><strong>@Product.Name</strong></h3>
        <p>@Product.Description</p>
        <p><strong>Price:</strong> @Product.Price?.ToString("C")</p>
        <p><strong>Weight:</strong> @Product.Weight kg</p>
    </a>

    <div class="product-card-actions">
        @if (Product.Available)
        {
            <label class="quantity-label" for="@($"qty-{Product.Id}")">Qty</label>
            <input id="@($"qty-{Product.Id}")"
                   type="number"
                   class="quantity-input"
                   min="1"
                   @bind="quantity" />

            <AddToOrderButton Product="Product"
                              Quantity="quantity"
                              NavigateOnAdd="false"
                              ReturnUrl="/products" />
        }
        else
        {
            <span class="add-to-order-btn unavailable">Unavailable</span>
        }
    </div>
</div>

@code {
    [Parameter]
    public Product Product { get; set; } = default!;

    private int quantity = 1;
}
