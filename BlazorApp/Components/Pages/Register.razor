@page "/account/register"
@using BlazorApp.Models
@using BlazorApp.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Identity
@inject UserManager<User> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Register</PageTitle>

<div class="main">
  <h3>Register</h3>

  @if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert alert-danger">@errorMessage</div>
  }

  <div class="col-md-4">
    <EditForm Model="@registerModel" OnValidSubmit="HandleRegister" FormName="registerForm">
      <DataAnnotationsValidator />

      <div class="mb-3">
        <label class="form-label">First Name:</label>
        <InputText @bind-Value="registerModel.FirstName" class="form-control" />
      </div>

      <div class="mb-3">
        <label class="form-label">Last Name:</label>
        <InputText @bind-Value="registerModel.LastName" class="form-control" />
      </div>

      <div class="mb-3">
        <label class="form-label">Email Address:</label>
        <InputText @bind-Value="registerModel.EmailAddress" type="email" class="form-control" />
      </div>

      <div class="mb-3">
        <label class="form-label">Password:</label>
        <InputText @bind-Value="registerModel.Password" type="password" class="form-control" />
        <ValidationMessage For="@(() => registerModel.Password)" class="text-danger" />
      </div>

      <div class="mb-3">
        <label class="form-label">Confirm Password:</label>
        <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="text-danger" />
        <InputText @bind-Value="registerModel.ConfirmPassword" type="password" class="form-control" />
      </div>

      <button type="submit" class="btn btn-primary">Register Today!</button>
    </EditForm>

    <div class="position-relative my-4">
      <div class="position-absolute top-50 start-0 w-100 border-top"></div>
      <div class="position-relative d-flex justify-content-center">
        <span class="bg-white px-3 text-muted small">Or</span>
      </div>
    </div>

    <div class="d-grid gap-2">
      <form action="/account/external-login" method="post" data-enhance="false" onsubmit="return true;">
        <AntiforgeryToken />
        
        <input type="hidden" name="provider" value="Google" />
        <input type="hidden" name="returnUrl" value="/account" />
        
        <button type="submit" class="btn w-100 bg-white border d-flex align-items-center justify-content-center gap-2 py-2 shadow-sm" style="color: #444; font-weight: 500;">
            
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
          </svg>
          
          Log in with Google
        </button>
      </form>

      <div>
        <p>Already have an account? <a href="/account/register" class="a-link">Log in!</a></p>
      </div>
    </div>
  </div>
</div>

@code {
  [SupplyParameterFromForm]
  private RegisterModel registerModel { get; set; } = default!;

  private string errorMessage = string.Empty;

  protected override void OnInitialized()
  {
    registerModel ??= new();
  }

  private async Task HandleRegister()
  {
    errorMessage = string.Empty;

    var newUser = new User
    {
      UserName = registerModel.EmailAddress,
      Email = registerModel.EmailAddress,
      LastName = registerModel.LastName,
      FirstName = registerModel.FirstName,
      EmailConfirmed = true
    };

    var result = await UserManager.CreateAsync(newUser, registerModel.Password);

    if (result.Succeeded)
    {
      NavigationManager.NavigateTo("/account/login");
    }
    else
    {
      errorMessage = string.Join(" | ", result.Errors.Select(e => e.Description));
    }
  }
}