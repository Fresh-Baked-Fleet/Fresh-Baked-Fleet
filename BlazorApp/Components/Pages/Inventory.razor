@page "/admin/inventory"
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin, Manager")]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject AppDbContext DbContext
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Inventory Management</PageTitle>

<div class="main mx-auto mt-4 " style="max-width: 1000px;">
  <div class="d-flex justify-content-between align-items-end mb-3">
    <h3 class="mb-0" style="color: #4A3B32;">Inventory Management</h3>
    <button class="btn btn-sm btn-earth shadow-sm" @onclick='() => NavigationManager.NavigateTo("/admin/inventory/add")'>
      <i class="bi bi-plus-lg"></i> Add New Product
    </button>
  </div>
  
  <hr />

  @if (inventoryProducts == null)
  { 
    <div class="d-flex justify-content-center my-5">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading inventory data...</span>
      </div>
    </div>
  }
  else if (!string.IsNullOrEmpty(fetchError))
  {
    <div class="alert shadow-sm text-center" style="background-color: #FAF9F6; border-left: 4px solid #C06C5B; color: #4A3B32;">
      <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @fetchError
    </div>
  }
  else if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert shadow-sm mb-4" style="background-color: #fff; border-left: 4px solid #C06C5B; color: #4A3B32;">
      <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @errorMessage
    </div>
  }    
  else if (!inventoryProducts.Any())
  {
    <div class="alert alert-info">No products found in the database.</div> 
  }
  else 
  {
    @if (!string.IsNullOrEmpty(successMessage))
    {
      <div class="alert shadow-sm mb-4" style="background-color: #FAF9F6; border-left: 4px solid #6B8A47; color: #4A3B32;">
        <i class="bi bi-check-circle-fill me-2" style="color: #6B8A47;"></i> @successMessage
      </div>
    }

    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          
          <table class="table table-earth-striped table-hover table-sm mb-0 align-middle">
            
            <thead class="table-earth-header">
              <tr>
                <th class="ps-4 py-3">Product Name</th>
                <th class="py-3">Price</th>
                <th class="py-3">Weight</th>
                <th class="py-3 text-center">Available</th>
                <th class="pe-4 py-3 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var product in inventoryProducts)
              {
                <tr>
                  <td class="ps-4 fw-medium" style="color: #4A3B32;">@product.Name</td>
                  <td>@product.Price?.ToString("C")</td>
                  <td>@product.Weight</td>
                  
                  <td class="text-center">
                    @if(product.Available)
                    {
                      <span class="badge rounded-pill px-3" style="background-color: #6B8A47;">Yes</span>
                    }
                    else
                    {
                      <span class="badge rounded-pill px-3" style="background-color: #C06C5B;">No</span>
                    }
                  </td>
                  
                  <td class="pe-4 text-end">
                    <div class="btn-group btn-group-sm" role="group">
                      <button class="btn btn-outline-earth" @onclick="() => EditProduct(product.Id)">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <button class="btn btn-outline-danger" @onclick="() => DeleteProduct(product.Id)">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>          
              }
            </tbody>
          </table> 
          
        </div>
      </div>
    </div>
  }
</div>

@code {
  private List<Product>? inventoryProducts;
  private string? fetchError;
  private string? errorMessage;
  private string? successMessage;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      fetchError = null;
      inventoryProducts = await DbContext.Products.ToListAsync();
    }
    catch (Exception)
    {
      inventoryProducts = new List<Product>(); 
      fetchError = "We are currently experiencing technical difficulties retrieving the inventory. Please try again later.";
    }
  }

  private void EditProduct(int productId)
  {
    NavigationManager.NavigateTo($"/admin/inventory/edit/{productId}");
  }

  private async Task DeleteProduct(int productId)
  {
    bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this product? This action cannot be undone.");

    if (!confirmed)
    {
      return;
    }
    
    try
    {
      errorMessage = null;

      var productToDelete = await DbContext.Products.FindAsync(productId);

      if (productToDelete != null)
      {
        DbContext.Products.Remove(productToDelete);
        await DbContext.SaveChangesAsync();
        inventoryProducts?.Remove(productToDelete);

        successMessage = "Product successfully deleted.";
      }
    }
    catch (Exception)
    {
      errorMessage = "We couldn't delete this product due to a database connection issue. Please try clicking delete again.";
    }
  }
}