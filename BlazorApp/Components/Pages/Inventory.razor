@page "/admin/inventory"
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@attribute [Authorize(Roles = "Admin, Manager")]

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject AppDbContext DbContext

<PageTitle>Inventory Management</PageTitle>

<div class="main mx-auto mt-4 " style="max-width: 1000px;">
  <div class="d-flex justify-content-between align-items-end mb-3">
    <h3 class="mb-0" style="color: #4A3B32;">Inventory Management</h3>
    <button class="btn btn-sm btn-earth shadow-sm">
      <i class="bi bi-plus-lg"></i> Add New Product
    </button>
  </div>
  
  <hr />

  @if (inventoryProducts == null)
  { 
    <div class="d-flex justify-content-center my-5">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading inventory data...</span>
      </div>
    </div>
  }
  else if (!string.IsNullOrEmpty(fetchError))
  {
    <div class="alert shadow-sm text-center" style="background-color: #FAF9F6; border-left: 4px solid #C06C5B; color: #4A3B32;">
      <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @fetchError
    </div>
  }
  else if (!inventoryProducts.Any())
  {
    <div class="alert alert-info">No products found in the database.</div> 
  }
  else 
  {
    <div class="card shadow-sm border-0">
      <div class="card-body p-0">
        <div class="table-responsive">
          
          <table class="table table-earth-striped table-hover table-sm mb-0 align-middle">
            
            <thead class="table-earth-header">
              <tr>
                <th class="ps-4 py-3">Product Name</th>
                <th class="py-3">Price</th>
                <th class="py-3">Weight</th>
                <th class="py-3 text-center">Available</th>
                <th class="pe-4 py-3 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var product in inventoryProducts)
              {
                <tr>
                  <td class="ps-4 fw-medium" style="color: #4A3B32;">@product.Name</td>
                  <td>@product.Price.ToString("C")</td>
                  <td>@product.Weight</td>
                  
                  <td class="text-center">
                    @if(product.Available)
                    {
                      <span class="badge rounded-pill px-3" style="background-color: #6B8A47;">Yes</span>
                    }
                    else
                    {
                      <span class="badge rounded-pill px-3" style="background-color: #C06C5B;">No</span>
                    }
                  </td>
                  
                  <td class="pe-4 text-end">
                    <div class="btn-group btn-group-sm" role="group">
                      <button class="btn btn-outline-earth" @onclick="() => EditProduct(product.Id)">
                        <i class="bi bi-pencil"></i> Edit
                      </button>
                      <button class="btn btn-outline-danger" @onclick="() => DeleteProduct(product.Id)">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </td>
                </tr>          
              }
            </tbody>
          </table> 
          
        </div>
      </div>
    </div>
  }
</div>

@code {
  private List<Product>? inventoryProducts;
  private string? fetchError;

  protected override async Task OnInitializedAsync()
  {
    try
    {
      fetchError = null;
      inventoryProducts = await DbContext.Products.ToListAsync();
    }
    catch (Exception)
    {
      inventoryProducts = new List<Product>(); 
      fetchError = "We are currently experiencing technical difficulties retrieving the inventory. Please try again later.";
    }
  }

  private void EditProduct(int productId)
  {
    Console.WriteLine($"Editing product with ID: {productId}");
  }

  private async Task DeleteProduct(int productId)
  {
    Console.WriteLine($"Attempting to delete product with ID: {productId}");
  }
}