@page "/admin/inventory/edit/{Id:int}"
@using BlazorApp.Data
@using BlazorApp.Models


@rendermode InteractiveServer

@attribute [Authorize(Roles = "Admin, Manager")]

@inject AppDbContext DbContext
@inject NavigationManager NavigationManager

<PageTitle>Edit @editProduct?.Name</PageTitle>

<div class="mx-auto mt-4" style="max-width: 800px;">
    
  <div class="d-flex align-items-center mb-4">
    <a href="/admin/inventory" class="text-decoration-none p-0 me-3" style="color: #6B4E31;">
      <i class="bi bi-arrow-left fs-4"></i>
    </a>
    <h3 class="mb-0" style="color: #4A3B32;">Edit Product</h3>
  </div>

  <div class="card shadow-sm border-0" style="background-color: #FAF9F6;">
    <div class="card-body p-4">
      
      @if (editProduct == null)
      {
        <div class="d-flex justify-content-center py-4">
          <div class="spinner-border text-secondary" role="status">
            <span class="visually-hidden">Loading product details...</span>
          </div>
        </div>
      }
      else if (!string.IsNullOrEmpty(errorMessage))
      {
        <div class="alert shadow-sm mb-4" style="background-color: #fff; border-left: 4px solid #C06C5B; color: #4A3B32;">
          <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @errorMessage
        </div>
      }
      else
      {
        <EditForm Model="editProduct" OnValidSubmit="UpdateProduct" FormName="EditProductForm">
          <DataAnnotationsValidator />

          <div class="mb-3">
            <label class="form-label fw-bold" style="color: #4A3B32;">Product Name</label>
            <InputText @bind-Value="editProduct.Name" class="form-control" />
            <ValidationMessage For="@(() => editProduct.Name)" class="text-danger" />
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label fw-bold" style="color: #4A3B32;">Price ($)</label>
              <InputNumber @bind-Value="editProduct.Price" class="form-control" placeholder="0.00" />
              <ValidationMessage For="@(() => editProduct.Price)" class="text-danger" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold" style="color: #4A3B32;">Weight</label>
              <InputNumber @bind-Value="editProduct.Weight" class="form-control" />
              <ValidationMessage For="@(() => editProduct.Weight)" class="text-danger" />
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold" style="color: #4A3B32;">Product Image</label>
            <InputFile OnChange="HandleImageUpload" class="form-control" accept="image/png, image/jpeg, image/webp" />

            @if (!string.IsNullOrEmpty(editProduct.ImagePath))
            {
              <div class="mt-3">
                <p class="text-muted small mb-1">Preview:</p>
                <img src="@editProduct.ImagePath" alt="Preview" class="img-thumbnail" style="max-height: 200px; border-radius: 8px;" />
              </div>
            }
          </div>

          <div class="form-check form-switch mb-4 mt-3">
            <InputCheckbox @bind-Value="editProduct.Available" class="form-check-input" id="availabilitySwitch" />
            <label class="form-check-label fw-bold" for="availabilitySwitch" style="color: #4A3B32;">
              Available for Sale
            </label>
          </div>

          <hr />
          
          <div class="d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-danger" @onclick="DeleteProduct">
              <i class="bi bi-trash"></i> Delete
            </button>
            <a href="/admin/inventory" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-earth px-4">Update Product</button>
          </div>

        </EditForm>
        }

    </div>
  </div>
</div>

@code {
  [Parameter]
  public int Id { get; set; }

  private Product? editProduct;

  private string? errorMessage;

  protected override async Task OnInitializedAsync()
  {
    editProduct = await DbContext.Products.FindAsync(Id);

    if (editProduct == null)
    {
      NavigationManager.NavigateTo("/admin/inventory");
    }
  }

  private async Task HandleImageUpload(InputFileChangeEventArgs e)
  {
    var file = e.File;

    if (file != null)
    {
      try
      {
        var maxAllowedSize = 5 * 1024 * 1024;

        using var stream = file.OpenReadStream(maxAllowedSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);

        var base64String = Convert.ToBase64String(memoryStream.ToArray());

        editProduct!.ImagePath = $"data:{file.ContentType};base64,{base64String}";
      }
      catch (Exception)
      {
        errorMessage = "That image is too large. Please select a file smaller than 5MB.";
      }
    }
  }

  private async Task UpdateProduct()
  {
    try
    {
      errorMessage = null;

      await DbContext.SaveChangesAsync();
    
      NavigationManager.NavigateTo("/admin/inventory");
    }
    catch (Exception)
    {
      errorMessage = "We couldn't update this product due to a database connection issue. Please try clicking update again.";
    }
  }

  private async Task DeleteProduct()
  {
    try
    {
      errorMessage = null;

      if (editProduct != null)
      {
        DbContext.Products.Remove(editProduct);
        await DbContext.SaveChangesAsync();
        NavigationManager.NavigateTo("/admin/inventory");
      }
    }
    catch (Exception)
    {
      errorMessage = "We couldn't delete this product due to a database connection issue. Please try clicking delete again.";
    }
  }
}