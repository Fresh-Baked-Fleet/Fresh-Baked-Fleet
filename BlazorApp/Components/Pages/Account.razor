@page "/account"
@using BlazorApp.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using BlazorApp.Data


@attribute [Authorize]

@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager

<PageTitle>My Account</PageTitle>

<div class="mx-auto mt-4 mb-5" style="max-width: 1000px;">
  <h3 style="color: #4A3B32; padding-bottom: 10px;">My Account</h3>
  <hr />

  @if (currentUser != null)
  {
    <div class="alert alert-success">
      <h4 class="alert-heading">Welcome, @currentUser.FirstName!</h4>
      <p>You are securely logged in.</p>
      <hr>
      <p class="mb-0"><strong>Full Name:</strong> @currentUser.FirstName @currentUser.LastName</p>
      <p class="mb-0"><strong>Registered Email:</strong> @currentUser.Email</p>
      <p class="mb-0"><strong>Registered Phone Number:</strong> @FormatPhoneNumber(currentUser.PhoneNumber)</p>
      <p class="mb-0"><strong>Residential Address:</strong> @GetFullAddress()</p>
      <p class="mb-0"><strong>Contact Preference:</strong> @(currentUser.Preference == ContactPreference.PhoneNumber ? "Phone Number" : "Email")</p>
      <hr />
      <div class="d-flex flex-wrap gap-2 mt-3">
        <a class="btn btn-earth shadow-sm" href="/account/edit">Edit Account Details</a>
        <a class="btn btn-outline-secondary" href="/products">Back to Shop</a>
      </div>
    </div>

    <hr />
    <h4>My Order History</h4>
    @if (userOrders == null)
    {
      <p><em>Loading orders...</em></p>
    }
    else if (!userOrders.Any())
    {
      <p>You haven't placed any orders yet.</p>
    }
    else
  {
    <div class="d-flex flex-column gap-3 mt-3">
      @foreach (var entry in userOrders.OrderBy(o => o.CreatedAt).Select((o, i) => new { Order = o, Index = i }))
      {
        <div class="card shadow-sm" style="border: 1px solid #E0DCD3;">
          <div class="card-header d-flex justify-content-between align-items-center" style="background-color: #FAF9F6; border-bottom: 1px solid #E0DCD3;">
            
            <strong style="color: #4A3B32;">Order #@(entry.Index + 1)</strong>
            
            <span class="badge" style="@(entry.Order.Status == OrderStatus.Pending ? "background-color: #F3E5AB; color: #4A3B32;" : "background-color: #6B4E31; color: #FAF9F6;")">
              @entry.Order.Status
            </span>
        </div>
        <div class="card-body">
          <p class="small mb-2" style="color: #6B4E31;">Placed on: @entry.Order.CreatedAt.ToLocalTime().ToString("f")</p>
          
          <table class="table table-sm table-borderless mb-0">
            <thead>
              <tr style="border-bottom: 1px solid #E0DCD3;">
                <th style="color: #4A3B32;">Item</th>
                <th style="color: #4A3B32;">Price</th>
                <th style="color: #4A3B32;">Qty</th>
                <th class="text-end" style="color: #4A3B32;">Subtotal</th>
              </tr>
            </thead>
            <tbody>
              @foreach (var item in entry.Order.Items)
              {
                <tr style="color: #4A3B32;">
                  <td>@item.Product.Name</td>
                  <td>@item.Product.Price?.ToString("C")</td>
                  <td>@item.Quantity</td>
                  <td class="text-end">@(((item.Product.Price ?? 0m) * item.Quantity).ToString("C"))</td>
                </tr>
              }
            </tbody>
            <tfoot style="border-top: 1px solid #E0DCD3;">
              <tr>
                <td colspan="3" class="text-end fw-bold pt-2" style="color: #4A3B32;">Order Total:</td>
                <td class="text-end fw-bold pt-2" style="color: #6B4E31;">
                  @entry.Order.Items.Sum(i => (i.Product.Price ?? 0m) * i.Quantity).ToString("C")
                </td>
              </tr>
              </tfoot>
            </table>
          </div>
        </div>
      }
    </div>
  }

    <AuthorizeView Roles="Admin">
      <Authorized>
        <div class="mt-4 p-3 rounded" style="background-color: #FAF9F6; border: 1px solid #E0DCD3;">
          <h5 style="color: #4A3B32;"><i class="bi bi-shield-lock-fill me-2" style="color: #6B4E31;"></i> Admin Controls</h5>
          <p class="text-muted small mb-2">Access the backend system to manage bakery products and stock.</p>
          <a href="/admin/inventory" class="btn btn-sm btn-earth">
            Go to Inventory Dashboard
          </a>
        </div>
      </Authorized>
    </AuthorizeView>
  }
  else
  {
    <p><em>Loading user data...</em></p>
  }
</div>

@code {
  private User? currentUser;

  private List<Order>? userOrders;

  private string GetFullAddress()
  {
    if (currentUser == null) return "Not provided";
    var parts = new[] { currentUser.StreetAddress, currentUser.City, currentUser.State, currentUser.ZipCode };
    var nonEmpty = parts.Where(p => !string.IsNullOrWhiteSpace(p)).ToArray();
    return nonEmpty.Length == 0 ? "Not provided" : string.Join(", ", nonEmpty);
  }

  protected override async Task OnInitializedAsync()
  {
    await LoadUserData();
  }

  private string FormatPhoneNumber(string? phone)
  {
    if (string.IsNullOrWhiteSpace(phone)) return "Not provided";

    var digits = new string(phone.Where(char.IsDigit).ToArray());

    if (digits.Length == 10)
    {
      return long.Parse(digits).ToString("(###) ###-####");
    }

    return phone;
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    // Reload user data each time the page is accessed to ensure edits are reflected
    if (!firstRender)
    {
      await LoadUserData();
      StateHasChanged();
    }
  }

  private async Task LoadUserData()
  {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    var userPrincipal = authState.User;

    if (userPrincipal.Identity?.IsAuthenticated == true)
    {
      currentUser = await UserManager.GetUserAsync(userPrincipal);

      if (currentUser != null)
      {
        userOrders = await DbContext.Orders
          .Include(o => o.Items)
            .ThenInclude(i => i.Product)
          .Where(o => o.UserId == currentUser.Id)
          .ToListAsync();
      }
    }
  }
}