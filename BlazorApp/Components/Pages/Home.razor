@page "/"
@inject IConfiguration Configuration
@using BlazorApp.Components

<PageTitle>@(Configuration["SiteConfig:Title"] ?? "Home")</PageTitle>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1>Fresh-Baked Fleet</h1>
        <p class="lead">A modern Fresh-Baked Fleet website home page.</p>
    </div>

    <div class="card p-4 mb-4">
        <h2>Site Overview</h2>
        <p>Fresh-Baked Fleet is a .NET-based B2B platform where users browse baking ingredients and submit order
            requests for manual review by sales staff. It supports public visitors, customers, and admins, with secure
            authentication, profile management, and full inventory CRUD operations, while focusing on desktop use and
            excluding automated checkout and payments.</p>
    </div>

    <div class="row g-4 align-items-stretch home-hero-row">
        <div class="col-12 col-lg-5 d-flex">
            <div class="card p-4 mb-4 home-hero-card w-100">
                <h2>
                    Welcome to Fresh-Baked Fleet
                </h2>
                <h4>
                    Welcome to Fresh-Baked Fleet
                    Lorem 30% off your first order with code <span class="text-primary">WELCOME30</span>!
                    Your one-stop shop for all things baking.
                </h4>
                <p class="mb-4">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et
                    dolore.
                </p>

                <div class="home-hero-actions">
                    <NavLink class="btn btn-primary" href="/weather">
                        Weather Demo
                    </NavLink>
                    <NavLink class="btn btn-outline-primary" href="https://trello.com/b/2C1fs8nh/fresh-baked-fleet" target="_blank">
                        Team Trello
                    </NavLink>
                    <a class="btn btn-outline-secondary" href="#next-steps">
                        Next Steps
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-7 d-flex">
            <div class="home-carousel w-100">
                @* Slideshow - managed through component data *@
                <ImageCarousel CarouselId="homeCarousel" Slides="GetCarouselSlides()" />
            </div>
        </div>

        <div class="col-12 col-md-6">
            <div class="card p-4 h-100">
                <h3>Want to know more about our collaboration</h3>
                <NavLink href="https://trello.com/b/2C1fs8nh/fresh-baked-fleet" target="_blank">
                    <p>Learn about our work and team manage task on Trello</p>
                </NavLink>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card p-4 h-100" id="next-steps">
                <h3>Next Steps</h3>
                <ul>
                    <li>Create an account to access your personalized dashboard.</li>
                    <li>View our products and services.</li>
                    <li>Contact us for more information.</li>
                </ul>
            </div>
        </div>
    </div>
</div>


@code {
    /// <summary>
    /// Define carousel slides here - easy to add/remove/modify
    /// </summary>
    private List<ImageCarousel.CarouselSlideData> GetCarouselSlides()
    {
        return new()
        {
            new()
            {
                ImageSrc = "/images/dan-gold.jpg",
                ImageAlt = "Dan Gold",
                Title = "Fresh-Baked Fleet",
                Description = "Warm goods served in style."
            },
            new()
            {
                ImageSrc = "/images/jan-antonin.jpg",
                ImageAlt = "Jan Antonin",
                Title = "Delicious Moments",
                Description = "Perfect for sharing and tasting."
            },
            new()
            {
                ImageSrc = "/images/taylor-baked.jpg",
                ImageAlt = "Taylor Baked",
                Title = "Artisan Baking",
                Description = "Handcrafted treats for every craving."
            }
        };
    }
}

