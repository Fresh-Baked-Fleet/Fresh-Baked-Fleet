@page "/"
@inject IConfiguration Configuration

<PageTitle>@(Configuration["SiteConfig:Title"] ?? "Home")</PageTitle>

<div class="container my-5">
    <div class="text-center mb-5">
        <h1>Fresh-Baked Fleet</h1>
        <p class="lead">A modern Fresh-Baked Fleet website home page.</p>
    </div>

    <div class="card p-4 mb-4">
        <h2>Site Overview</h2>
        <p>Welcome to your new app.</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-md-6">
            <div class="card p-4 h-100">
                <h3>Home Page </h3>
                <p>This page is configured to load the site title, description, and welcome message from <code>appsettings.json</code>.</p>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card p-4 h-100">
                <h3>Next Steps</h3>
                <ul>
                    <li>Update the text in <code>SiteConfig</code> to match your website.</li>
                    <li>Add sections for team members, project goals, or features.</li>
                    <li>Use the side menu to navigate to Counter and Weather pages.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
