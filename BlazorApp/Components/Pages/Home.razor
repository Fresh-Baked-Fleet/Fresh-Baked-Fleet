@page "/"
@inject IConfiguration Configuration
@using BlazorApp.Components
@using BlazorApp.Services
@using BlazorApp.Models
@inject ProductService ProductService

<PageTitle>@(Configuration["SiteConfig:Title"] ?? "Home")</PageTitle>

<div class="home-page">
    <section class="hero-banner">
        <div class="hero-banner-inner">
            <h1>Fresh-Baked Fleet</h1>
        </div>
    </section>

    <section class=" hero-carousel-section py-4">
        <div class="container px-0">
            <div class="hero-carousel">
                @* Slideshow - managed through component data *@
                <ImageCarousel CarouselId="heroCarousel" Slides="HeroCarouselSlides()" />
            </div>
        </div>
    </section>

    <section class="container">
        <div class="row justify-content-center g-4 align-items-stretch home-hero-row">
            <div class="col-12 col-lg-10">
                <div class="home-hero-card">
                    <h2 class="display-5 fw-bold text-center">
                        Welcome to Fresh-Baked Fleet
                    </h2>
                    <h4 class="lead text-center">
                        The best place to obtain your ingredients for perfectly baked goods.
                    </h4>

                    <div class="home-hero-actions">
                        <NavLink class="btn btn-primary" href="/products">
                            Our products
                        </NavLink>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container">
        <h2 class="display-5 fw-bold text-center mt-5 mb-4">
            Featured Products
        </h2>
        <div class="products-container">
            @foreach (var product in products)
            {
                <ProductCard Product="product" />
            }
        </div>
    </section>

    <h2 class="display-4 fw-bold text-center mt-5 mb-4" style="color: #4a3b32;">
        Learn About Us!
    </h2>

    <section class="container">
        <div class="row justify-content-center g-4 align-items-stretch home-hero-row">
            <div class="col-12 col-lg-10">
                <div class="home-hero-card">
                    <h2 class="display-5 fw-bold text-center">
                        Our Mission
                    </h2>
                    <h4 class="lead text-center">
                        To provide the freshest, highest-quality ingredients to our customers, ensuring that every baked
                        creation is a masterpiece of flavor and texture.
                    </h4>
                </div>
            </div>
        </div>
    </section>

    <section class="container">
        <div class="row justify-content-center g-4 align-items-stretch home-hero-row">
            <div class="col-12 col-lg-10">
                <div class="home-hero-card">
                    <h2 class="display-5 fw-bold text-center">
                        Our Story
                    </h2>
                    <h4 class="lead text-center">
                        Fresh-Baked Fleet was born out of a passion for baking and a desire to share that passion with
                        others. We understand the importance of quality ingredients in creating delicious baked goods,
                        and we are committed to sourcing only the best for our customers.
                    </h4>
                </div>
            </div>
        </div>
    </section>

    <section class="container">
        <div class="row justify-content-center g-4 align-items-stretch home-hero-row">
            <div class="col-12 col-lg-10">
                <div class="home-hero-card">
                    <h2 class="display-5 fw-bold text-center">
                        Our Vision
                    </h2>
                    <h4 class="lead text-center">
                        To be the leading supplier of premium baking ingredients, for your business. So you can focus on
                        what you do best - baking delicious treats for your customers.
                    </h4>
                </div>
            </div>
        </div>
    </section>


</div>

