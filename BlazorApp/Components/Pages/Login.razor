@page "/account/login"
@using BlazorApp.Data
@using BlazorApp.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@inject SignInManager<User> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="main">
  <h3>Login</h3>
  
  @if (ErrorMessage == "database_offline")
  {
    <div class="alert alert-danger mb-4" role="alert">
      <span class="bi bi-exclamation-exclamation-triangle-fill me-2" aria-hidden="true"></span>
      <strong>We're currently experiencing technical difficulties.</strong> Our dabatase is temporarily offline, but our team is actively working to restore it. Please try again a bit later.
    </div>
  }
  else if (ErrorMessage == "true")
  {
    <div class="alert alert-danger mb-4" role="alert">
      <span class="bi bi-exclamation-circle-fill me-2" aria-hidden="true"></span>
      There was a problem authenticating your account. Please try again.
    </div>
  }

  @if (!string.IsNullOrEmpty(errorMessage))
  {
    <div class="alert alert-danger">@errorMessage</div>
  }

  <div class="col-md-4">
    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin" FormName="loginForm">
      <DataAnnotationsValidator />

      <div class="mb-3">
        <label class="form-label">Email Address:</label>
        <input type="email" name="emailAddress" class="form-control" required />
        <ValidationMessage For="@(() => loginModel.EmailAddress)" class="text-danger" />
      </div>

      <div class="mb-3">
        <label class="form-label">Password:</label>
        <input type="password" name="password" class="form-control" required" />
        <ValidationMessage For="@(() => loginModel.Password)" class="text-danger" />
      </div>

      <button type="submit" class="btn btn-primary">Login</button>
    </EditForm>

    <div class="position-relative my-4">
      <div class="position-absolute top-50 start-0 w-100 border-top"></div>
      <div class="position-relative d-flex justify-content-center">
        <span class="bg-white px-3 text-muted small">Or</span>
      </div>
    </div>

    <div class="d-grid gap-2">
      <form action="/account/external-login" method="post" data-enhance="false" onsubmit="return true;">
        <AntiforgeryToken />
        
        <input type="hidden" name="provider" value="Google" />
        <input type="hidden" name="returnUrl" value="/account" />
        
        <button type="submit" class="btn w-100 bg-white border d-flex align-items-center justify-content-center gap-2 py-2 shadow-sm" style="color: #444; font-weight: 500;">
            
          <svg width="20" height="20" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4" />
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853" />
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05" />
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335" />
          </svg>
          
          Log in with Google
        </button>
      </form>

      <div>
        <p>Don't have an account? <a href="/account/register" class="a-link">Register today!</a></p>
      </div>
    </div>
  </div>
</div>

@code {
  [SupplyParameterFromQuery(Name = "error")]
  public string? ErrorMessage { get; set; }

  [SupplyParameterFromForm]
  private LoginModel loginModel { get; set; } = default!;
  private string errorMessage = string.Empty;

  protected override void OnInitialized()
  {
    loginModel ??= new();
  }

  private async Task HandleLogin()
  {
    errorMessage = string.Empty;

    var result = await SignInManager.PasswordSignInAsync(
      loginModel.EmailAddress,
      loginModel.Password,
      isPersistent: false,
      lockoutOnFailure: false);

    if (result.Succeeded)
    {
      NavigationManager.NavigateTo("/account");
    }
    else if (result.IsNotAllowed)
    {
      errorMessage = "Login rejected: Account is not allowed (usually means unconfirmed email).";
    }
    else if (result.IsLockedOut)
    {
      errorMessage = "Login rejected: Account locked due to too many failed attempts.";
    }
    else
    {
      errorMessage = "Login rejected: Incorrect email or password.";
    }
  }
}