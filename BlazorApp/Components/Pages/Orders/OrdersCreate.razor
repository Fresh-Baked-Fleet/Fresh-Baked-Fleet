@page "/orders/create"
@attribute [Authorize]
@using BlazorApp.Models
@using BlazorApp.Services
@using BlazorApp.Data
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<User> UserManager
@inject AppDbContext DbContext
@inject ProductService ProductService
@inject OrderCartService Cart
@inject NavigationManager Navigation

@rendermode InteractiveServer
@implements IDisposable

<PageTitle>Create Order</PageTitle>

<div class="bakery-container shadow-sm mt-4 mb-5 mx-auto" style="max-width: 1000px;">
    <h3 style="color: #4A3B32; border-bottom: 2px solid #E0DCD3; padding-bottom: 10px;">Create Order</h3>

    <div class="d-flex flex-wrap gap-3 align-items-center mt-4 mb-4">
        <div class="flex-grow-1">
            <label class="form-label small fw-bold mb-1" style="color: #6B4E31;">Select Product</label>
            <select class="bakery-input w-100" @bind="SelectedProductId">
                @foreach (var p in products)
                {
                    <option value="@p.Id">@p.Name</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label small fw-bold mb-1" style="color: #6B4E31;">Quantity</label><br />
            <input type="number" class="bakery-input" style="width: 100px;" @bind="quantity" min="1" />
        </div>

        <div class="align-self-end">
            <button class="btn btn-bakery-primary" @onclick="AddItem">Add to Order</button>
        </div>
    </div>

    <h4 style="color: #6B4E31;" class="mt-5">Order Summary</h4>
    <hr style="border-color: #E0DCD3;" />

    @if (!Cart.Items.Any())
    {
        <p class="text-muted fst-italic">Your cart is empty. Add some items above to get started!</p>
    }

    @if (!string.IsNullOrEmpty(submitError))
    {
        <div class="alert shadow-sm mb-4" style="background-color: #fff; border-left: 4px solid #C06C5B; color: #4A3B32;">
            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @submitError
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert shadow-sm mb-4" style="background-color: #fff; border-left: 4px solid #C06C5B; color: #4A3B32;">
            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #C06C5B;"></i> @errorMessage
        </div>
    }

    @foreach (var item in Cart.Items)
    {
        <div class="bakery-card mb-3 p-3 d-flex flex-row align-items-center shadow-sm">
            <img src="@item.Product.ImagePath"
                 style="width:80px;height:80px;object-fit:cover;border-radius:8px; border: 1px solid #E0DCD3;" />

            <div class="ms-3 flex-grow-1" style="color: #4A3B32;">
                <h5 class="mb-1" style="color: #6B4E31;">@item.Product.Name</h5>
                <p class="mb-1 small text-muted">@item.Product.Description</p>
                <div class="small mt-2">
                    <strong>Price:</strong> @item.Product.Price?.ToString("C") <span class="mx-2 text-muted">|</span>
                    <strong>Weight:</strong> @item.Product.Weight kg <span class="mx-2 text-muted">|</span>
                    <strong>Quantity:</strong> @item.Quantity
                </div>
            </div>
            <button class="delete-btn ms-3" @onclick="() => RemoveItem(item)" title="Remove Item">
                ❌
            </button>
        </div>
    }

    @if (Cart.Items.Any())
    {
        <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 p-3 rounded shadow-sm" style="background-color: #fff; border: 1px solid #E0DCD3;">
            <div>
                <h6 class="mb-1 text-muted">Total Items: @Cart.Items.Sum(x => x.Quantity)</h6>
                <h4 class="mb-0" style="color: #4A3B32;">
                    Order Total: <strong style="color: #6B4E31;">@Cart.Items.Sum(x => (x.Product.Price ?? 0m) * x.Quantity).ToString("C")</strong>
                </h4>
            </div>
            <button class="btn btn-bakery-primary btn-lg px-4 mt-3 mt-sm-0"
                    @onclick="SubmitOrder"
                    disabled="@(!Cart.Items.Any())"
                    title="@(Cart.Items.Any() ? null : "Add items to your cart first")">
                Submit Order
            </button>
        </div>
    }

    @if (showPopup)
    {
        <div class="bakery-alert mt-4 shadow-sm">
            <h4 style="color: #4A3B32; margin-bottom: 5px;">Order Created Successfully!</h4>
            <p style="color: #6B4E31; margin-bottom: 15px; font-size: 1.05rem;">
                Thank you for trusting Fresh-Baked Fleet, our sales team will reach out soon.
            </p>
            <div>
                <button class="btn btn-bakery-outline" @onclick="ClosePopup">Close</button>
                <button class="btn btn-bakery-primary ms-2" @onclick="GoToAccount">View My Orders</button>
            </div>
        </div>
    }
</div>

@code {
    List<Product> products = new();
    string? errorMessage;
    string submitError = string.Empty;
    int SelectedProductId;
    int quantity = 1;
    bool showPopup;

    [SupplyParameterFromQuery(Name = "productId")]
    public int? ProductId { get; set; }

    [SupplyParameterFromQuery(Name = "quantity")]
    public int? QueryQuantity { get; set; }

    async Task SubmitOrder()
    {
        if (!Cart.Items.Any())
        {
            submitError = "You must add at least one item to your order.";
            return;
        }

        submitError = string.Empty;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
            return;

        try
        {
            errorMessage = null;

            var newOrder = new Order
            {
                UserId = user.Id,
                CreatedAt = DateTime.UtcNow,
                Status = OrderStatus.Pending,
                Items = Cart.Items.Select(item => new OrderItem
                {
                    ProductId = item.ProductId,
                    Quantity = item.Quantity
                }).ToList()
            };

            DbContext.Orders.Add(newOrder);
            await DbContext.SaveChangesAsync();

            showPopup = true;
        }
        catch (Exception)
        {
            errorMessage = "We couldn't process your order at the moment due to a database connection issue. Please try again.";
        }
    }

    async Task ClosePopup()
    {
        showPopup = false;
        await Cart.ClearAsync();
    }

    void GoToAccount()
    {
        Navigation.NavigateTo("/account");
    }

    protected override async Task OnInitializedAsync()
    {
        Cart.OnChange += HandleCartChanged;
        await Cart.EnsureLoadedAsync();
        products = await ProductService.GetProductsAsync();

        if (products.Any())
        {
            SelectedProductId = products.First().Id;
        }

        if (ProductId.HasValue)
        {
            var product = products.FirstOrDefault(p => p.Id == ProductId.Value);
            if (product != null)
            {
                await Cart.AddItemAsync(product, QueryQuantity ?? 1);
                SelectedProductId = product.Id;
                Navigation.NavigateTo("/orders/create", replace: true);
            }
        }
    }

    async Task RemoveItem(OrderItem item)
    {
        await Cart.RemoveItemAsync(item);
    }

    async Task AddItem()
    {
        submitError = string.Empty;

        var product = products.FirstOrDefault(x => x.Id == SelectedProductId);
        if (product == null)
            return;

        await Cart.AddItemAsync(product, quantity);
    }

    private void HandleCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Cart.OnChange -= HandleCartChanged;
}
